# Copy this file to .env and fill real values locally.
# Do not commit .env to GitHub.

CAMERA_HOST=192.168.40.21
CAMERA_PORT=554
CAMERA_USERNAME=admin
CAMERA_PASSWORD=CHANGE_ME
CAMERA_CHANNEL=102
SNAPSHOT_OUTPUT=outputs/rtsp_test_snapshot.jpg

# Optional local internal face recognition defaults.
# Keep disabled unless explicitly approved and configured on the production server.
FACE_RECOGNITION_ENABLED=false
FACE_RECOGNITION_BACKEND=auto
FACE_REFERENCE_DIR=backend/data/face-reference
FACE_EMBEDDINGS_DIR=backend/data/face-embeddings
FACE_MATCH_THRESHOLD=0.60
